# ===========================================
# 众爱联盟 - 环境变量配置
# ===========================================

# 应用基础配置
NUXT_APP_NAME=众爱联盟
NUXT_APP_ENV=development

# JWT 密钥（生产环境请使用强随机字符串）
NUXT_JWT_SECRET=your-jwt-secret-change-in-production

# 微信小程序配置
NUXT_WECHAT_APP_ID=your-wechat-app-id
NUXT_WECHAT_APP_SECRET=your-wechat-app-secret

# PostgreSQL 数据库连接
NUXT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zhongai

# 服务端口
NITRO_PORT=3000

# CORS 允许的源（逗号分隔）
NUXT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
